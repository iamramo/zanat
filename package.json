{
  "name": "@iamramo/zanat",
  "private": true,
  "description": "A skill hub for AI agents - manage and distribute agent skills",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "rm -rf packages/*/dist",
    "prebuild": "npm run clean",
    "build": "npm run build --workspaces",
    "build:core": "npm run build -w packages/core",
    "build:cli": "npm run build -w packages/cli",
    "dev:cli": "npm run dev -w packages/cli",
    "typecheck": "npm run typecheck --workspaces",
    "lint": "eslint packages/*/src/**/*.ts"
  },
  "keywords": [
    "ai",
    "agents",
    "skills",
    "mcp",
    "cli"
  ],
  "author": "Yurchi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamramo/zanat.git"
  },
  "bugs": {
    "url": "https://github.com/iamramo/zanat/issues"
  },
  "homepage": "https://github.com/iamramo/zanat#readme",
  "engines": {
    "node": ">=22.0.0"
  }
}
