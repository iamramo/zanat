# Zanat Environment Configuration
# Copy this file to .env and customize the values

# Hub Configuration
# The URL of the zanat hub repository
ZANAT_HUB_URL=https://github.com/iamramo/zanat-hub.git

# The branch to use from the hub repository
ZANAT_HUB_BRANCH=main

# Development Settings
# Set to 'production' in production environments
NODE_ENV=development

# Enable debug logging
DEBUG=false
