{
  "name": "@iamramo/zanat-cli",
  "version": "0.5.7",
  "description": "CLI for zanat - a skill hub for AI agents",
  "type": "module",
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "bin": {
    "zanat": "bin/zanat.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "npm run build -w @iamramo/zanat-core",
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@iamramo/zanat-core": "^0.5.1",
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai",
    "agents",
    "skills",
    "mcp",
    "cli"
  ],
  "author": "Yurchi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamramo/zanat.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/iamramo/zanat/issues"
  },
  "homepage": "https://github.com/iamramo/zanat#readme"
}
